{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "jsx": "preserve",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "src/*": ["./src/*"],
      "layouts/*": ["./src/layouts/*"],
      "pages/*": ["./src/pages/*"],
      "components/*": ["./src/components/*"],
      "boot/*": ["./src/boot/*"],
      "stores/*": ["./src/stores/*"],
      "@protocol": ["../server/protocol.ts"],
      "vue": ["./node_modules/vue"],
      "vue/*": ["./node_modules/vue/*"],
      "vue-router": ["./node_modules/vue-router"],
      "vue-router/*": ["./node_modules/vue-router/*"],
      "vue-i18n": ["./node_modules/vue-i18n"],
      "vue-i18n/*": ["./node_modules/vue-i18n/*"],
      "quasar": ["./node_modules/quasar"],
      "quasar/*": ["./node_modules/quasar/*"],
      "pinia": ["./node_modules/pinia"],
      "pinia/*": ["./node_modules/pinia/*"],
      "codemirror": ["./node_modules/codemirror"],
      "@codemirror/*": ["./node_modules/@codemirror/*"],
      "echarts": ["./node_modules/echarts"],
      "echarts/*": ["./node_modules/echarts/*"]
    },
    "types": ["@quasar/app-vite"],
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "components/**/*.vue",
    "composables/**/*.ts",
    "layouts/**/*.vue",
    "pages/**/*.vue",
    "router/**/*.ts",
    "services/**/*.ts",
    "stores/**/*.ts",
    "../../GnauralCore/ui/**/*.ts",
    "../../GnauralCore/ui/**/*.vue",
    "../../BodyMonitorCore/ui/**/*.ts",
    "../../BodyMonitorCore/ui/**/*.vue",
    "env.d.ts"
  ],
  "exclude": ["node_modules", ".quasar", "dist"]
}
